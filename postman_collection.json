{
  "info": {
    "name": "ERP Automação - Império do Gás",
    "description": "Coleção completa de endpoints da API REST do ERP de rastreabilidade de remessas GLP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "erp-imperiogas-v2"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "inboundId", "value": "", "type": "string" },
    { "key": "inboundItemId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "personId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "People",
      "description": "Gerenciamento de pessoas. person_type: PF | PJ",
      "item": [
        {
          "name": "Listar todas as Pessoas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/people",
            "description": "Retorna todas as pessoas cadastradas."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) pm.collectionVariables.set('personId', data[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar Pessoa por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/people/{{personId}}",
            "description": "Retorna uma pessoa pelo UUID."
          }
        },
        {
          "name": "Criar Pessoa Física (PF)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/people",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João da Silva\",\n  \"document\": \"123.456.789-00\",\n  \"phone\": \"(11) 99999-0001\",\n  \"person_type\": \"PF\"\n}"
            },
            "description": "Cria uma pessoa física. person_type obrigatório: PF | PJ"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) pm.collectionVariables.set('personId', data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Criar Pessoa Jurídica (PJ)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/people",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Distribuidora ABC Ltda\",\n  \"document\": \"12.345.678/0001-99\",\n  \"phone\": \"(11) 3333-0001\",\n  \"trade_name\": \"ABC Gás\",\n  \"person_type\": \"PJ\"\n}"
            },
            "description": "Cria uma pessoa jurídica com trade_name."
          }
        },
        {
          "name": "Atualizar Pessoa",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/people/{{personId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João da Silva Atualizado\",\n  \"phone\": \"(11) 98888-0001\",\n  \"person_type\": \"PF\"\n}"
            }
          }
        },
        {
          "name": "Deletar Pessoa",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/people/{{personId}}"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "description": "Clientes vinculados a pessoas. Requer person_id existente em /api/people.",
      "item": [
        {
          "name": "Listar todos os Clientes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/clients",
            "description": "Retorna clientes com pessoa associada (eager load)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) pm.collectionVariables.set('clientId', data[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar Cliente por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/clients/{{clientId}}"
          }
        },
        {
          "name": "Criar Cliente",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/clients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person_id\": \"{{personId}}\",\n  \"payment_deadline_days\": 30,\n  \"active\": true\n}"
            },
            "description": "Cria um cliente vinculado a uma pessoa existente.\nperson_id é obrigatório."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) pm.collectionVariables.set('clientId', data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Atualizar Cliente",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/clients/{{clientId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_deadline_days\": 15,\n  \"active\": true\n}"
            }
          }
        },
        {
          "name": "Deletar Cliente",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/clients/{{clientId}}"
          }
        }
      ]
    },
    {
      "name": "Inbounds (Entradas de Estoque)",
      "description": "Remessas de GLP. Cada entrada pode ter múltiplos itens por categoria.",
      "item": [
        {
          "name": "Listar todas as Entradas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inbounds",
            "description": "Retorna remessas com items[]. Cada item tem category, quantity, availableQuantity, unitCost, subtotal."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) {",
                  "  pm.collectionVariables.set('inboundId', data[0].id);",
                  "  if (data[0].items && data[0].items.length > 0) {",
                  "    pm.collectionVariables.set('inboundItemId', data[0].items[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Criar Entrada (com itens por categoria)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/inbounds",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceNumber\": \"NF-001234\",\n  \"truckPlate\": \"ABC-1234\",\n  \"items\": [\n    {\n      \"category\": \"GLP_13KG_CHEIO\",\n      \"quantity\": 100,\n      \"unitCost\": 45.00\n    },\n    {\n      \"category\": \"GLP_20KG_CHEIO\",\n      \"quantity\": 50,\n      \"unitCost\": 72.00\n    },\n    {\n      \"category\": \"GLP_13KG_VAZIO\",\n      \"quantity\": 30,\n      \"unitCost\": 15.00\n    }\n  ]\n}"
            },
            "description": "Registra nova remessa.\n\nCategorias válidas:\n- GLP_13KG_CHEIO / GLP_13KG_VAZIO\n- GLP_20KG_CHEIO / GLP_20KG_VAZIO\n- GLP_45KG_CHEIO / GLP_45KG_VAZIO\n\nO sistema define automaticamente:\n- availableQuantity = quantity\n- status = ABERTO\n- totalAmount = Σ (quantity × unitCost)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('inboundId', data.id);",
                  "  if (data.items && data.items.length > 0) {",
                  "    pm.collectionVariables.set('inboundItemId', data.items[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders (Vendas)",
      "description": "Pedidos de venda. Referencia InboundItems de lotes específicos para rastreabilidade e desconto automático de estoque.\n\nsaleType: AVISTA | FIADO\nstatus: ABERTO | ENTREGUE | CANCELADO",
      "item": [
        {
          "name": "Listar todos os Pedidos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders",
            "description": "Retorna pedidos com cliente, status e total."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) pm.collectionVariables.set('orderId', data[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar Pedido por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        },
        {
          "name": "Criar Pedido - À Vista",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"driverId\": null,\n  \"saleType\": \"AVISTA\",\n  \"status\": \"ABERTO\",\n  \"items\": [\n    {\n      \"inboundItemId\": \"{{inboundItemId}}\",\n      \"quantity\": 5,\n      \"unitPrice\": 60.00\n    }\n  ]\n}"
            },
            "description": "Registra nova venda.\n\nRegras:\n- clientId e saleType são obrigatórios\n- inboundItemId: UUID do item de lote (GET /api/inbounds → items[].id)\n- quantity NÃO pode exceder availableQuantity do lote\n- O sistema subtrai quantity do availableQuantity automaticamente\n- totalAmount = Σ (quantity × unitPrice)\n\nsaleType: AVISTA | FIADO\nstatus: ABERTO | ENTREGUE | CANCELADO"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) pm.collectionVariables.set('orderId', data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Criar Pedido - Fiado (com vencimento)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"saleType\": \"FIADO\",\n  \"dueDate\": \"2026-07-04\",\n  \"status\": \"ABERTO\",\n  \"items\": [\n    {\n      \"inboundItemId\": \"{{inboundItemId}}\",\n      \"quantity\": 10,\n      \"unitPrice\": 58.00\n    }\n  ]\n}"
            },
            "description": "Venda fiado com data de vencimento (due_date)."
          }
        },
        {
          "name": "Atualizar Status do Pedido",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ENTREGUE\"\n}"
            },
            "description": "Altera status do pedido.\nValores válidos: ABERTO | ENTREGUE | CANCELADO\n\nATENÇÃO: NÃO estorna estoque automaticamente."
          }
        },
        {
          "name": "Deletar Pedido",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/{{orderId}}",
            "description": "Remove um pedido. ATENÇÃO: NÃO estorna estoque."
          }
        }
      ]
    }
  ]
}
